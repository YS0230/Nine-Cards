{
  "name": "nine-cards",
  "private": true,
  "version": "0.1.0",
  "description": "九支仔 — 即時多人連線對戰網頁遊戲",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "slice": "node scripts/slice.mjs",
    "audio": "node scripts/audio.mjs",
    "money": "node scripts/money.mjs",
    "players": "node scripts/players.mjs",
    "build": "npm run slice && npm run audio && npm run money && npm run players && npm run build --workspace client",
    "start": "npm start --workspace server",
    "test": "npm run test --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "sharp": "^0.33.5"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "sharp@0.33.5": true
  }
}
